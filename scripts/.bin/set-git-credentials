#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 2 || $# -gt 3 ]]; then
    echo "Usage: $0 <name> <email> [signing-key-path]" >&2
    exit 1
fi

name=$1
email=$2
signing_key=${3:-}

file=~/.gitconfig.local

git config --file "$file" user.name "$name"
git config --file "$file" user.email "$email"

if [[ -n $signing_key ]]; then
    git config --file "$file" user.signingkey "$signing_key"
    git config --file "$file" gpg.format ssh
    git config --file "$file" commit.gpgsign true
    git config --file "$file" tag.gpgsign true
fi
